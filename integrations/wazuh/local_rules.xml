<!--
  Copy rules into /var/ossec/etc/rules/local_rules.xml on the Wazuh manager
  (or include this file from ruleset). Then restart wazuh-manager.
-->
<group name="netaudit,">

  <rule id="100500" level="3">
    <decoded_as>json</decoded_as>
    <field name="integration">netaudit</field>
    <description>Network Audit (netaudit) finding</description>
    <options>no_full_log</options>
  </rule>

  <rule id="100501" level="12">
    <if_sid>100500</if_sid>
    <field name="netaudit.severity">critical</field>
    <description>netaudit CRITICAL: $(netaudit.title) on $(netaudit.device)</description>
    <mitre>
      <id>T1562</id>
    </mitre>
  </rule>

  <rule id="100502" level="10">
    <if_sid>100500</if_sid>
    <field name="netaudit.severity">high</field>
    <description>netaudit HIGH: $(netaudit.title) on $(netaudit.device)</description>
  </rule>

  <rule id="100503" level="7">
    <if_sid>100500</if_sid>
    <field name="netaudit.severity">medium</field>
    <description>netaudit MEDIUM: $(netaudit.title) on $(netaudit.device)</description>
  </rule>

  <rule id="100504" level="5">
    <if_sid>100500</if_sid>
    <field name="netaudit.severity">low|info</field>
    <description>netaudit LOW/INFO: $(netaudit.title) on $(netaudit.device)</description>
  </rule>

  <rule id="100510" level="12">
    <if_sid>100500</if_sid>
    <field name="netaudit.rule_id">FG-POLICY-ANY-ANY|ACL-PERMIT-ANY|SC-ACL-PERMIT-ANY</field>
    <description>netaudit: overly permissive firewall/ACL on $(netaudit.device)</description>
  </rule>

  <rule id="100511" level="10">
    <if_sid>100500</if_sid>
    <field name="netaudit.rule_id">FG-SYSLOG-MISSING|SYSLOG-MISSING|SC-SYSLOG-MISSING</field>
    <description>netaudit: device $(netaudit.device) not sending syslog (SIEM gap)</description>
  </rule>

</group>
